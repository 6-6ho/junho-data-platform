# ============================================================
# junho-data-platform 환경변수
# ============================================================
# 이 파일을 복사하여 .env로 저장하고 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================

# === Network (2-Node 구성) ===
# 랩탑 노드 IP (데스크톱에서 Postgres 접근용)
LAPTOP_IP=192.168.x.x
# 데스크톱 노드 IP (랩탑에서 Shop/Airflow/Spark 접근용)
DESKTOP_IP=192.168.x.x

# === Database (PostgreSQL) ===
POSTGRES_PASSWORD=postgres

# === Telegram 알림 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Realestate Monitor (성북구 월세) ===
# 비워두면 위 TELEGRAM_* 로 폴백 (같은 채팅에 섞임)
REALESTATE_BOT_TOKEN=
REALESTATE_CHAT_ID=

# === MinIO (Object Storage) ===
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me

# === Airflow ===
# Fernet key 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-fernet-key-here
AIRFLOW_SECRET_KEY=change-this-secret
AIRFLOW_PASSWORD=admin

# === Shop Admin ===
ADMIN_PASSWORD=admin
JWT_SECRET=change-me-in-production

# === Feature Flags ===
ENABLE_SHOP_STREAMING=false

# === Deployment (deploy_desktop.sh 에서 사용) ===
# DESKTOP_HOST=192.168.x.x
# DESKTOP_USER=your-username
